include ../mixins/alear.pug

doctype html
html(lang="en")
	head
		meta(charset="UTF-8")
		meta(name="viewport", content="width=device-width, initial-scale=1.0")
		meta(name="author", content="Trần Kim Quang")
		script(src="https://cdn.tailwindcss.com/")
		script(src="/tailwind.config.js")
		link(href="/media/logo/logo.svg", rel="icon", type="image/x-icon")
		link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css")

		title #{pageTitle}
	body(class=`font-font2`)

		+alert-success(2000)
		+alert-error(2000)

		div(class=`flex`)
			include ../partials/sibar.pug					
			main(class=`h-screen overflow-y-auto scoll-auto w-full scrollbarmain`)
				include ../partials/header.pug
				block main

	script(src="/tinymce/tinymce.min.js") 
	script(src="/admin/js/style.js")
	script(src="/admin/js/tinymce-config.js")