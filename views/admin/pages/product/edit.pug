extends ../../layouts/default.pug
include ../../mixins/select-tree.pug
include ../../mixins/quay-lai.pug
include ../../mixins/them-moi.pug
include ../../mixins/khung-table.pug
include ../../mixins/cap-nhat.pug

block header
	+quay-lai("Quay lại danh sách sản phẩm", `/${admin}/product`)
	+cap-nhat("Cập nhật")(buttonSubmitEditProduct="")
block main
	- if(role.permisstion.includes('products_edit'))
		+khung-table("Chỉnh sửa sản phẩm")
			form(
				action=`/${admin}/product/edit/${product.id}?_method=PATCH`
				method="POST"
				target=''
				autocomplete = "on"
				enctype="multipart/form-data"
				formsSubmitEditProduct
			)
				div(class=`flex flex-col gap-y-[10px]`)
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
						label(
							for="title"
							class=`text-[16px]`
						) Tiêu đề
							span(class="text-[red]")  *
						input(
							type="text", name="title" id="title"
							class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
							placeholder="Nhập tiêu đề sản phẩm..."
							required
							value = product.title
						)
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
						label(
							for="product_category_id"
							class=`text-[16px]`
						) Danh mục
							span(class="text-[red]")  *
						select(id='product_category_id' name='product_category_id' 
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`)
							option(value='') --- Chọn danh mục ---
							+select-tree(category, '', product.product_category_id)
					div(class=`flex flex-col items-left gap-y-[10px]`)
						label(
							for="description"
							class=`text-[16px]`
						) Mô tả
						textarea(
							id="description" name="description" 
							placeholder="Nhập mô tả sản phẩm..."
							class=""
							textarea-mce 
						) !{product.description}
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
						label(
							for="price"
							class=`text-[16px]`
						) Giá
							span(class="text-[red]")  *
						input(
							type="number", name="price" id="price"
							class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
							min='0'
							placeholder="Nhập giá sản phẩm..."
							required
							value = product.price
						)
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
						label(
							for="discountPercentage"
							class=`text-[16px]`
						) % giảm giá
							span(class="text-[red]")  *
						input(
							type="number", name="discountPercentage" id="discountPercentage"
							class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
							min='0'
							max='100'
							placeholder="Nhập phần trăm giảm giá..."
							value = product.discountPercentage
						)
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
						label(
							for="stock"
							class=`text-[16px]`
						) Số lượng
							span(class="text-[red]")  *
						input(
							type="number", name="stock" id="stock"
							class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
							min='1'
							placeholder="Nhập số lượng sản phẩm..."
							required
							value = product.stock
						)
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4` upload-image)
						label(
							for="thumbnail"
							class=`text-[16px]`
						) Ảnh
						input(
							type="file", name="thumbnail" id="thumbnail"
							class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2 file:bg-[#06BC84] file:border-[0] file:rounded-[10px] file:px-[10px] file:py-[5px] file:hover:cursor-pointer hover:cursor-pointer file:hover:rounded-[20px] file:text-[white]`
							placeholder="Nhập ảnh sản phẩm..."
							accept='image/*'
							upload-image-input
						)
						img(src=product.thumbnail, alt=""
							class=`w-[25%] h-auto rounded-[10px] cursor-pointer`
							upload-image-preview)
					div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
						label(
							for="position"
							class=`text-[16px]`
						) Vị trí
							span(class="text-[red]")  *
						input(
							type="number", name="position" id="position"
							class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
							placeholder="Tự động tăng..."
							value = product.position
						)
					div(class=`flex justify-center gap-[20px]`)
						div(class=`flex flex-row gap-[10px]`)
							input(
								type="radio", name='status' value="active" id="active"
								class=``
								required
								checked = (product.status == 'active' ? true : false)
							)
							label(
								for="active"
								class=`font-bold text-[20px] capitalize`
							) Hoạt động
						div(class=`flex flex-row gap-[10px]`)
							input(
								type="radio", name='status' value="inactive" id="inactive"
								required
								checked = (product.status == 'inactive' ? true : false)
							)
							label(
								for="inactive"
								class=`font-bold text-[20px] capitalize`
							) dừng Hoạt động
				button(type="submit"
					class=`text-[15px] px-[10px] border-[1px] hover:border-[0px] border-[#FA6B04] bg-[#FA6B04] text-[white] rounded-[10px] py-[10px] block ml-auto hidden`
				) Cập nhật
			
	- else
		div(class="" no-view-permission) 