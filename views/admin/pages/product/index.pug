extends ../../layouts/default.pug
include ../../mixins/box-actions.pug
include ../../mixins/fillter-status.pug
include ../../mixins/search.pug
include ../../mixins/pagination.pug
include ../../mixins/khung-table.pug
include ../../mixins/quay-lai.pug
include ../../mixins/them-moi.pug

block header
	+quay-lai("Quay lại tổng quan", `/${admin}/main`)
	- if(role.permisstion.includes('products_create'))
		+them-moi("+ Thêm mới", `/${admin}/product/create`)


block main
	- if(role.permisstion.includes('products_view'))
		- if(role.permisstion.includes('products_fillterandsearch'))
			- if(product.length > 0 && pagination.totalProduct > 1)
				+khung-table("Lọc theo trang thái")
					div(class=`flex flex-wrap gap-[10px] justify-between p-[10px] items-center`)
						+fillter-status(fillerStatus)
						+search(key)
		- if(role.permisstion.includes('products_quickActionMenu'))
			if(product.length > 0  && pagination.totalProduct > 1)
				+khung-table("hành động")
					+box-actions(`/${admin}/product/change-multi`, statusOption)
		
		- if(role.permisstion.includes('products_sort'))
			if(product.length > 0  && pagination.totalProduct > 1)
				+khung-table("Sắp xếp")
					div(class="flex gap-[10px] items-center my-[20px] justify-center" sort) 
						select(name="" class="outline-[#1C404C] outline-[1px] pl-[10px] rounded-[10px] py-[10px] text-[18px]")
							option(value="position-desc")  Vị trí giảm dần
							option(value="position-asc")  Vị trí tăng dần
							option(value="title-asc")  Tên sản phẩm tăng dần
							option(value="title-desc")  Tên sản phẩm giảm dần
							option(value="price-asc")  Giá tăng dần
							option(value="price-desc")  Giá giảm dần
							option(value="updatedAt-asc")  Ngày sửa đổi tăng dần
							option(value="updatedAt-desc")  Ngày sửa đổi giảm dần
							option(value="stock-asc")  Số lượng tăng dần
							option(value="stock-desc")  Số lượng giảm dần
						button(type="button" class="rounded-[10px] bg-[#1C404C] text-[white] text-[18px] p-[10px]") Reset

		+khung-table("Danh sách sản phẩm")
			if(product.length > 0)
				table(class=`text-center mt-[5px] text-[14px]`)
					thead(class=`h-[50px]`)
						tr(class="")
							if(pagination.totalProduct > 1)
								th(class=`h-full`)
									input(
										type="checkbox", 
										name="checkAll"
										class=`appearance-none w-[20px] h-[20px] border-[1px] border-[black]/20 rounded-[10px] checked:bg-[#263238] hover:cursor-pointer`
									)
							th STT
							th(class=``) Hình ảnh
							th(class="w-full") Sản phẩm
							th Giá
							th Vị trí
							th(class="") Trạng thái
							th(class="") Tạo bởi
					tbody
						each it, i in product
							tr(
								class=`group hover:transition-all hover:duration-700 hover:rounded-[10px] hover:cursor-pointer border-b-[1px] last:border-[0px] border-b-[black]/40 hover:bg-[black]/20`
								title=`Sản phẩm ${it.title}`
							)
								if(pagination.totalProduct > 1)
									td(class=`relative z-[50]`)
										input(
											type="checkbox", 
											name="checkItem"
											class=`appearance-none h-[20px] border-[1px] border-[black]/20 rounded-[10px] checked:bg-[#FA6B04] checked:border-[0px] hover:cursor-pointer relative z-[50] px-[10px]`
											value = it.id
										)
								td(class=`relative z-[5] class="px-[20px]"`) #{pagination.limit * (pagination.current - 1) + i + 1}
								td(class=`w-1/6 px-[20px]`)
									img(
										src=it.thumbnail, 
										onerror="this.src='/admin/images/photo.png'"
										alt=it.title 
										class=`rounded-[10px] w-full`
										nameImageImg = it.nameImage
									)
								td(
									class=`text-left px-[20px] grow`
									tickItem
								)
									div(class="flex justify-between") 
										div(class="flex flex-col") 
											div(class="") #{it.title}
											div(class="group-hover:flex group-hover:items-center hidden group-hover:block gap-[10px]")
												- if(role.permisstion.includes("products_edit"))
													a(
														href=`/${admin}/product/edit/${it.id}`
														type="button" class=`text-[#00712D] text-[10px]`
														title="Chỉnh sửa sản phẩm"
													) Sửa
												- if(role.permisstion.includes("products_delete"))
													button(
														type="button" 
														class=`text-[red]/80 text-[10px]`
														button-delete = `/${admin}/product/delete/${it.id}
														`
														title="Xóa sản phẩm"
													) Xóa
										div(class="flex items-center") 
											a(href=`/${admin}/product/detail/${it.id}` class="mr-[10px] text-[15px] fa-solid fa-eye flex hidden text-[#4C30A5] group-hover:flex z-[50] " title="Xem chi tiết sản phẩm")

								td(class=" px-[5px]") #{it.priceNew}.000đ
								td(class=`w-min`)
									- if(role.permisstion.includes('products_edit'))
										input(
											link=`/${admin}/product/change-position/${it.id}`
											type="number"
											name="position"
											value=it.position
											class=`max-w-[70px] mx-auto outline-[#FA6B04]`
											min='1'
										)
									- else
										div(class="") #{it.position}
								td(class="px-[10px] w-max")
									- if(role.permisstion.includes('products_changeProductStatus'))
										- if(it.status == 'active')
											button(
												link=(`/${admin}/product/change-status/inactive/${it.id}`)
												type="button"
												class=`bg-[#06BC84] w-max text-[white] text-[10px] rounded-[10px] px-[10px] py-[2px]` title="Click vào để đổi thành dừng hoạt động") Hoạt động
										- else
											button(
												link=`/${admin}/product/change-status/active/${it.id}`
												type="button"
												class=`bg-[red]/80 w-max text-[white] text-[10px] rounded-[10px] px-[10px] py-[2px]` title="Click vào để đổi thành hoạt động"
											) Dừng hoạt động
									- else
										- if(it.status == 'active')
											button(
												type="button"
												class=`bg-[#06BC84] w-max text-[white] text-[10px] rounded-[10px] px-[10px] py-[2px]`) Hoạt động
										- else
											button(
												type="button"
												class=`bg-[red]/80 text-[white] w-max text-[10px] rounded-[10px] px-[10px] py-[2px]`
											) Dừng hoạt động
								td(class=`w-max`)
									div(class="w-max text-[blue/40] text-[10px]")  #{it.createdBy}
									div(class="w-max text-[10px]")  #{it.createdAtFormat}
			else
				div(class="text-center text-[20px]") Không có sản phẩm nào
									

			+pagination(pagination)
	
	- else
		div(class="" no-view-permission) 