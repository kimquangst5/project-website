extends ../../layouts/default.pug
include ../../mixins/pagination.pug
include ../../mixins/khung-table.pug
include ../../mixins/setting-box.pug

block main
	+khung-table('Thông tin tài khoản')
		form(
			action=`/${admin}/accounts/create`
			method="POST"
			target=''
			autocomplete = "on"
			class="py-[20px]"
		)
			div(class=`flex flex-col gap-y-[10px]`)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="useName"
						class=`text-[16px]`
					) Tên đăng nhập
						span(class="text-[red]")  *
					input(
						type="text", name="useName" id="useName"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập tên tài khoản..."
						required
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="password"
						class=`text-[16px]`
					) Mật khẩu:
						span(class="text-[red]")  *
					input(
						type="password", name="password" id="password"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập mật khẩu..."
						required
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="confirmPassword"
						class=`text-[16px]`
					) Xác minh mật khẩu:
						span(class="text-[red]")  *
					input(
						type="password", name="confirmPassword" id="confirmPassword"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Xác minh mật khẩu..."
						required
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="email"
						class=`text-[16px]`
					) Email
						span(class="text-[red]")  *
					input(
						type="email", name="email" id="email"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập email của bạn..."
						required
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="email"
						class=`text-[16px]`
					) Nhóm quyền
						span(class="text-[red]")  *
					select(name="role_id" id="role_id" class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`)
						option(value="") ---Chọn nhóm quyền---
						each it in roles
							option(value=it.id id="role_id") #{it.title}
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="fullName"
						class=`text-[16px]`
					) Họ và tên:
						span(class="text-[red]")  *
					input(
						type="text", name="fullName" id="fullName"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Họ và tên đầy đủ ..."
						required
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="phone"
						class=`text-[16px]`
					) Số điện thoại
						span(class="text-[red]")  *
					input(
						type="number", name="phone" id="phone"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập số điện thoại..."
						required
						min="10" max="10"
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="birthday"
						class=`text-[16px]`
					) Ngày sinh
					input(
						type="date", name="birthday" id="birthday"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Ngày sinh: dd/mm/yyyy"
					)
			button(type="submit"
						class=`text-[15px] px-[10px] border-[1px] hover:border-[0px] border-[#FA6B04] bg-[#FA6B04] text-[white] rounded-[10px] py-[10px] block ml-auto`
					) Tạo tài khoản