extends ../../layouts/default.pug
include ../../mixins/pagination.pug
include ../../mixins/khung-table.pug
include ../../mixins/setting-box.pug
include ../../mixins/quay-lai.pug
include ../../mixins/them-moi.pug

block header
	+quay-lai("Quay lại tổng quan", `/${admin}/main`)
	+them-moi("Cập nhật", `/${admin}/accounts/edit/${id}?_method=PATCH`)

block main
	+khung-table('Thông tin tài khoản')
		form(
			action=`/${admin}/accounts/edit/${id}?_method=PATCH`
			method="POST"
			target=''
			autocomplete = "on"
			class="py-[20px]"
		)
			div(class=`flex flex-col gap-y-[10px]`)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="useName"
						class=`text-[16px]`
					) Tên đăng nhập
						span(class="text-[red]")  *
					input(
						type="text", name="useName" id="useName"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập tên tài khoản..."
						required
						value = account.useName
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="email"
						class=`text-[16px]`
					) Email
						span(class="text-[red]")  *
					input(
						type="email", name="email" id="email"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập email của bạn..."
						required
						value = account.email

					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="email"
						class=`text-[16px]`
					) Nhóm quyền
						span(class="text-[red]")  *
					select(name="role_id" id="role_id" class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`)
						option(value="") ---Chọn nhóm quyền---
						each it in roles
							option(value=it.id selected = (it.id == account.role_id ? true : false)) #{it.title}
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="fullName"
						class=`text-[16px]`
					) Họ và tên:
						span(class="text-[red]")  *
					input(
						type="text", name="fullName" id="fullName"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Họ và tên đầy đủ ..."
						required
						value = account.fullName
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="phone"
						class=`text-[16px]`
					) Số điện thoại
						span(class="text-[red]")  *
					input(
						type="number", name="phone" id="phone"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Nhập số điện thoại..."
						required
						value = account.phone
					)
				div(class=`flex flex-row items-center gap-y-[10px] grid grid-cols-4`)
					label(
						for="birthday"
						class=`text-[16px]`
					) Ngày sinh
					input(
						type="date", name="birthday" id="birthday"
						class=`p-[5px] rounded-[5px] border-[1px] border-[black]/10 outline-[black]/20 col-span-2`
						placeholder="Ngày sinh: dd/mm/yyyy"
						value = account.birthday
					)
			button(type="submit"
				class=`text-[15px] px-[10px] border-[1px] hover:border-[0px] border-[#FA6B04] bg-[#FA6B04] text-[white] rounded-[10px] py-[10px] block ml-auto`
			) Cập nhật