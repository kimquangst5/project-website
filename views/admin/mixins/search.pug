mixin search(key)
	form(
		form-search
		class=`rounded-[10px] text-[12px] h-[30px] border-[1px] border-[black]/40 truncate`
	)
		i(class="fa-light fa-magnifying-glass px-[10px] opacity-0 duration-700")
		input(type="search", name=""
			class=`h-full outline-none px-[10px] bg-transparent`
			placeholder='Tìm kiếm......'
			value=key
		)
		button(
			type="submit"
			class=`bg-adminColorTertiary text-adminColorHeadline h-full px-[10px]`
		) Tìm kiếm
