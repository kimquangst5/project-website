mixin fillter-status(item)
	div(class=`flex flex-wrap items-center gap-[10px]`)
		each it in item
			button(
				type="button"
				class=`border-[1px] border-adminColorTertiary text-adminColorHeadline h-full px-[10px] py-[5px] rounded-[7px] hover:bg-adminColorTertiary hover:text-adminColorHeadline text-[12px]`
				button-status = it.lable
			) #{it.value}