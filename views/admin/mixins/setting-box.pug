mixin box-setting(icon, link, title, desc = 'Không có mô tả')
	div(class="flex items-center py-[20px]") 
		a(href=link class=`${icon} text-[25px] text-adminColorHeadline`)
		div(class="ml-[20px] flex flex-col")
			a(href=link class="text-adminColorHeadline hover:text-[#686E92] text-[12px] text-wrap") #{title}
			div(class="text-[10px] text-adminColorHeadline text-wrap") #{desc}