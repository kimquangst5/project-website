mixin box-setting(icon, link, title, desc = 'Không có mô tả')
	div(class="flex items-center py-[20px]") 
		a(href=link class=`${icon} text-[25px] text-[#686E92]`)
		div(class="ml-[20px] flex flex-col")
			a(href=link class="text-[#1A1A26] hover:text-[#686E92] text-[12px] text-wrap") #{title}
			div(class="text-[10px] text-[#1A1A26] text-wrap") #{desc}