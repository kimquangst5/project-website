extends ../../../layouts/default.pug
include ../../../mixins/dieu-huong.pug

block main
	+dieu-huong("Lời mời đã gửi")

	include ../../../partials/friend-btn.pug

	div(class="")
		div(class="container")
			each it in users
				div(class="" box-user)
					div(class="") #{it.fullName}
					button(btn-add-friend = it.id class=`hidden`) Kết bạn

					button(btn-cancel-friend = it.id ) Hủy