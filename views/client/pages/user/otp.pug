extends ../../layouts/default.pug
include ../../mixins/dieu-huong.pug

block main
	+dieu-huong("Mã OTP")
	div(class="container mt-[50px]") 
		div(class="flex justify-center items-center")
			form(action="/member/otp" method="POST" class="bg-[white] p-[30px] rounded-[5px] w-1/2 flex flex-col gap-[15px]")
					div(class="flex flex-col gap-y-[10px]") 
						label(for="email" class=`text-chu`) Email
							span(class=`text-[red] text-[18px]`)  *
						div(class="border-[1px] border-[black]/30 rounded-[5px] flex gap-[10px] items-center px-[5px] py-[10px]")
							i(class="fa-regular fa-user text-[black]/80 icon px-[10px]")
							input(type="text", id="email" name="email" class=`outline-none w-full` placeholder="Email của bạn" readonly value=user.email)
					div(class="flex flex-col gap-y-[10px]") 
						label(for="otp" class=`text-chu`) Mã OTP
							span(class=`text-[red] text-[18px]`)  *
						div(class="border-[1px] border-[black]/30 rounded-[5px] flex gap-[10px] items-center px-[5px] py-[10px]")
							i(class="fa-regular fa-user text-[black]/80 icon px-[10px]")
							input(type="number", id="otp" name="otp" class=`outline-none w-full` placeholder="Mã OTP gồm có 6 số đc gửi qua email")
					button(type="submit" class="bg-chu text-[white] p-[15px] text-center rounded-[6px]") Gửi mã OTP
